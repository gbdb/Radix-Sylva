# =============================================================================
# Radix Sylva — copier vers .env :  cp .env.example .env
# PostgreSQL obligatoire (port 5433 = docker compose dans ce repo).
# Jardin bIOT (autre repo) : voir biot/.env.example (port 5434).
# =============================================================================

# --- Django ---
# SECRET_KEY : une clé par environnement (ne pas réutiliser celle de BIOT en prod)
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-me-local-dev-only

DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- Base de données (obligatoire) ---
# docker compose up -d  dans radixsylva/  puis :
DATABASE_URL=postgres://radixsylva:radixsylva@127.0.0.1:5433/radixsylva

# --- API publique ---
CORS_ALLOW_ALL_ORIGINS=True

# Clés pour /api/v1/sync/* (liste séparée par des virgules ; vide = dev sans clé)
# RADIX_SYLVA_SYNC_API_KEYS=
